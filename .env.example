# Copy this file to .env and fill in the values before running docker compose.
# .env is gitignored — never commit real secrets.

# Generate with: openssl rand -hex 32
SECRET_KEY=

# PostgreSQL password (used by both the db and app containers)
POSTGRES_PASSWORD=

# QR code for receipt
RECEIPT_QR=https://www.youtube.com/watch?v=dQw4w9WgXcQ
RECEIPT_QR_TITLE=Free beer by this link