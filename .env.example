# Copy this file to .env and fill in the values before running docker compose.
# .env is gitignored — never commit real secrets.

# Generate with: openssl rand -hex 32
SECRET_KEY=

# PostgreSQL password (used by both the db and app containers)
POSTGRES_PASSWORD=

# Currency symbol displayed in the UI (frontend only, backend is not affected)
# Available options stored in "client/src/currency.js"
VITE_CURRENCY=USD

# QR code for receipt
RECEIPT_QR=https://www.youtube.com/watch?v=dQw4w9WgXcQ
RECEIPT_QR_TITLE=Free beer by this link

# Allowed CORS origins (comma-separated). Include all hosts that serve the React frontend.
# Dev without Docker: http://localhost:5173
# Dev with Docker:    http://localhost:8501
# With nginx on 80:   http://localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:8501

# Additional logging and openAPI schemas. Default value is True if no "DEBUG" key found in env
DEBUG=False